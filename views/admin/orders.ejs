<!-- 관리자 주문상태 관리 화면 -->
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>관리자 주문상태 관리</title>
</head>
<body>
<h1>관리자 주문상태 관리</h1>

<table border="1">
    <tr>
        <th>주문번호</th>
        <th>회원 ID</th>
        <th>회원 이름</th>
        <th>총 금액</th>
        <th>현재 상태</th>
        <th>상태 변경</th>
    </tr>

    <% orders.forEach(order => { %>
        <tr>
            <td><%= order.id %></td>
            <td><%= order.username %></td>
            <td><%= order.name %></td>
            <td><%= order.total_price %>원</td>
            <td><%= order.status %></td>
            <td>
                <form action="/admin/orders/update/<%= order.id %>" method="POST">
                    <select name="status">
                        <option value="주문완료" <%= order.status === '주문완료' ? 'selected' : '' %>>주문완료</option>
                        <option value="배송준비중" <%= order.status === '배송준비중' ? 'selected' : '' %>>배송준비중</option>
                        <option value="배송중" <%= order.status === '배송중' ? 'selected' : '' %>>배송중</option>
                        <option value="배송완료" <%= order.status === '배송완료' ? 'selected' : '' %>>배송완료</option>
                        <option value="주문취소" <%= order.status === '주문취소' ? 'selected' : '' %>>주문취소</option>
                    </select>

                    <button type="submit">변경</button>
                </form>
            </td>
        </tr>
    <% }) %>
</table>

<br>
<a href="/admin">← 관리자 메인으로</a>
</body>
</html>