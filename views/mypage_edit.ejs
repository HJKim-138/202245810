<!-- 마이페이지의 회원정보 수정 화면 -->

<h2>회원정보 수정</h2>

<form action="/mypage/edit" method="POST">
    <div>
        <label>아이디</label>
        <input
                type="text"
                value="<%= user.username %>"
                disabled
        >
    </div>

    <div>
        <label>이름</label>
        <input
                type="text"
                name="name"
                value="<%= user.name %>"
                required
        >
    </div>

    <div>
        <label>새 비밀번호</label>
        <input
                type="password"
                name="password"
                placeholder="변경하지 않으려면 비워두세요"
        >
    </div>

    <button type="submit">
        수정하기
    </button>
</form>

<a href="/mypage/info">← 내 정보로 돌아가기</a>